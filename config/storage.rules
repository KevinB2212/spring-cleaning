rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos - public read, auth required to write
    match /profiles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Accusation photos - auth required for both
    match /accusations/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Notice photos - auth required for both
    match /notices/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
